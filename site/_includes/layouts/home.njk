{% extends "layouts/base.njk" %}

{% block head %}
{% include "partials/jinn-tap-styles.njk" %}
{% endblock %}

{% block body %}
<main class="home">
  <section class="hero">
    <div class="hero__copy">
      <p class="eyebrow">Any XML schema, starting with TEI &amp; JATS</p>
      <h1>Rich text editing, directly on your XML</h1>
      <p class="lede">
        A rich-text editor web component where the content in the editor maps directly onto the
        XML — no round trips or lossy exports.
      </p>
      <div class="hero__actions">
        <a class="button button--primary" href="{{ '/guide/' | prefixUrl }}">Get started</a>
        <a class="button" href="{{ '/schema/' | prefixUrl }}">Schema reference</a>
        <a class="button" href="{{ '/' | prefixUrl }}#try-it">Try it</a>
      </div>
    </div>
    <div class="hero__visual">
      <img src="{{ '/jinntap-logo.png' | prefixUrl }}" alt="JinnTap" width="280" height="280">
    </div>
  </section>

  <section class="features">
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="currentColor">
          <path fill-rule="evenodd" d="M6 3.5A1.5 1.5 0 0 1 7.5 2h1A1.5 1.5 0 0 1 10 3.5v1A1.5 1.5 0 0 1 8.5 6v1H14a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0V8h-5v.5a.5.5 0 0 1-1 0v-1A.5.5 0 0 1 2 7h5.5V6A1.5 1.5 0 0 1 6 4.5zM8.5 5a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5zM0 11.5A1.5 1.5 0 0 1 1.5 10h1A1.5 1.5 0 0 1 4 11.5v1A1.5 1.5 0 0 1 2.5 14h-1A1.5 1.5 0 0 1 0 12.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm4.5.5A1.5 1.5 0 0 1 7.5 10h1a1.5 1.5 0 0 1 1.5 1.5v1A1.5 1.5 0 0 1 8.5 14h-1A1.5 1.5 0 0 1 6 12.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5zm4.5.5a1.5 1.5 0 0 1 1.5-1.5h1a1.5 1.5 0 0 1 1.5 1.5v1a1.5 1.5 0 0 1-1.5 1.5h-1a1.5 1.5 0 0 1-1.5-1.5zm1.5-.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5z"/>
        </svg>
      </div>
      <h2>Structure-preserving</h2>
      <p>What you edit is what you save: XML elements become HTML custom elements in the editor, keeping every attribute and structural feature.</p>
    </article>
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="4" x2="6" y2="20"/>
          <line x1="12" y1="4" x2="12" y2="20"/>
          <line x1="18" y1="4" x2="18" y2="20"/>
          <circle cx="6" cy="15" r="2"/>
          <circle cx="12" cy="8" r="2"/>
          <circle cx="18" cy="12" r="2"/>
        </svg>
      </div>
      <h2>Meant to be customized</h2>
      <p>Instead of trying to cover every possible use case, JinnTap is designed to be customized to match your particular XML encoding practice and workflow.</p>
    </article>
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="5" y="3" width="14" height="18" rx="1.5"/>
          <line x1="8.5" y1="8" x2="15.5" y2="8"/>
          <line x1="8.5" y1="12" x2="15.5" y2="12"/>
          <line x1="8.5" y1="16" x2="12.5" y2="16"/>
        </svg>
      </div>
      <h2>One stop configuration</h2>
      <p>A single JSON config defines the expected XML structure, toolbar buttons, shortcuts and input rules — the main extension point.</p>
    </article>
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 16a6 6 0 0 0 6-6c0-1.655-1.122-2.904-2.432-4.362C10.254 4.176 8.75 2.503 8 0c0 0-6 5.686-6 10a6 6 0 0 0 6 6M6.646 4.646l.708.708c-.29.29-1.128 1.311-1.907 2.87l-.894-.448c.82-1.641 1.717-2.753 2.093-3.13"/>
        </svg>
      </div>
      <h2>Simple CSS for styling</h2>
      <p>Because XML elements are mapped to HTML custom elements, styling is straightforward using standard CSS.</p>
    </article>
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="3,5 13,5 20,12 13,19 3,19"/>
          <circle cx="7.5" cy="12" r="1.3" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <h2>Semantic annotations</h2>
      <p>Optional integration with authority databases like GeoNames, GND and others to encode entities.</p>
    </article>
    <article class="feature">
      <div class="feature__icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="14" rx="2"/>
          <line x1="3" y1="8" x2="21" y2="8"/>
          <circle cx="6" cy="6" r="0.6" fill="currentColor" stroke="none"/>
          <circle cx="8.5" cy="6" r="0.6" fill="currentColor" stroke="none"/>
          <line x1="9" y1="21" x2="15" y2="21"/>
          <line x1="12" y1="18" x2="12" y2="21"/>
        </svg>
      </div>
      <h2>Client-side</h2>
      <p>While JinnTap is meant to be integrated into more complex applications like TEI Publisher, it does itself not require a server. Everything runs in the client.</p>
    </article>
  </section>

  <section class="try-it" id="try-it">
    <div class="try-it__header">
      <h2>Try it</h2>
      <p>Type in the editors below, use the toolbar, and toggle source view (<code>&lt;/&gt;</code>) to inspect the XML. 
      Content will be saved to your browser, so you can come back to it later,
      but nothing is sent to a server.</p>
    </div>
    {% include "partials/pb-page-open.njk" %}
      <div class="try-it__demo">
        <h3 class="try-it__label">TEI</h3>
        {% include "partials/jinn-tap-embed.njk" %}
      </div>
      <div class="try-it__demo">
        <h3 class="try-it__label">JATS</h3>
        <p>Same content as above, but in <a href="https://www.niso.org/publications/z3996-2024-jats">JATS</a> format:</p>
        {% set format = "jats" %}
        {% include "partials/jinn-tap-embed.njk" %}
      </div>
      <jinn-toast></jinn-toast>
    </pb-page>
  </section>
</main>
{% endblock %}

{% block scripts %}
{% include "partials/jinn-tap-scripts.njk" %}
{% endblock %}
